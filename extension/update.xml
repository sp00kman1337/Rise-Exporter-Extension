<?xml version='1.0' encoding='UTF-8'?>
<!--
  Auto-update manifest for Rise 360 Bulk Export extension.

  HOW IT WORKS
  ────────────
  Edge/Chrome check this file periodically. If the version here is higher than
  the installed version, the browser downloads the .crx at the codebase URL and
  applies the update automatically.

  TO PUBLISH AN UPDATE
  ────────────────────
  1. Bump "version" in manifest.json
  2. Package the extension as a signed .crx:
       - Open edge://extensions (or chrome://extensions)
       - Enable Developer mode → Pack extension → point at this folder
       - Save the generated .crx to this repo as rise-bulk-export.crx
  3. Update the version attribute below to match manifest.json
  4. Commit and push both files to GitHub

  NOTE: The appid below is a placeholder. Replace it with the actual extension
  ID shown on the extensions page after your first install.
-->
<gupdate xmlns='http://www.google.com/update2/response' protocol='2.0'>
  <app appid='piomggcofepggjpkeafdpmdcmilageif'>
    <updatecheck
      version='1.0'
      codebase='https://raw.githubusercontent.com/sp00kman1337/Rise-Exporter-Extension/main/rise_file_exporter_v1.0.crx' />
  </app>
</gupdate>
